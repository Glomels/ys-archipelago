# Ys I Chronicles AP — Environment Configuration
# Copy this file to .env and edit paths for your system.

# Game directory (folder containing ys1plus.exe)
GAME_DIR="$HOME/Library/Application Support/CrossOver/Bottles/Steam/drive_c/Program Files (x86)/Steam/steamapps/common/Ys I"

# CrossOver/Wine paths (macOS)
WINEPREFIX="$HOME/Library/Application Support/CrossOver/Bottles/Steam"
WINE="$HOME/Applications/CrossOver.app/Contents/SharedSupport/CrossOver/lib/wine/x86_64-unix/wine"

# Archipelago installation
ARCHIPELAGO_DIR="/Applications/Archipelago.app/Contents/MacOS"
ARCHIPELAGO_WORLDS="$ARCHIPELAGO_DIR/lib/worlds"

# AP server connection (used by setup_mod.sh)
AP_SERVER="archipelago.gg:38281"
AP_SLOT="Adol"
AP_PASSWORD=""
