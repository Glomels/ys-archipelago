#!/bin/bash
# Usage: ysspeed <multiplier>
# Examples: ysspeed 2.5, ysspeed 1 (normal), ysspeed 0.5 (slow-mo)

export WINEPREFIX="/Users/luis/Library/Application Support/CrossOver/Bottles/Steam"
export WINEDEBUG=-all
export WINEMSYNC=1
WINE="/Users/luis/Applications/CrossOver.app/Contents/SharedSupport/CrossOver/lib/wine/x86_64-unix/wine"
SPEED_FILE="/Users/luis/Library/Application Support/CrossOver/Bottles/Steam/drive_c/speedhack.txt"

if [ -z "$1" ]; then
    current=$(cat "$SPEED_FILE" 2>/dev/null || echo "not set")
    echo "Current speed: ${current}x"
    echo "Usage: ysspeed <multiplier>"
    exit 0
fi

echo "$1" > "$SPEED_FILE"

# Auto-inject if not already injected (inject is idempotent)
"$WINE" "C:\\inject.exe" 2>&1 | grep -q "SUCCESS\|WARNING" && echo "Speed set to ${1}x (injected)" || echo "Speed set to ${1}x"
